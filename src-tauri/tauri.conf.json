{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Google Notify",
  "version": "0.1.0",
  "identifier": "com.unischool.notify.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Google Notify",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; connect-src 'self' https://classroom.googleapis.com https://www.googleapis.com https://chat.googleapis.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/unischool-sg/google_notify/releases/download/latest/update-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0MTZBRjkxOTBFRTU3NjUKUldSbFYrNlFrYThXRklMRjZzN05sMXFOU1VlMnBPNkp3WG5hSTg3ZkpIYTJRQ1ZSTWlqeUFmTXcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/256x256@2x.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
